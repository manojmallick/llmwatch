{
  "title": "LLMWatch — Production AI Quality Observatory",
  "description": "Real-time LLM groundedness, hallucination rate, regressions, and the LLMWatch agent's autonomous remediation audit trail. Import via Dashboards → Create New → Dashboard Studio → Source.",
  "schemaVersion": "1.1",
  "visualizations": {
    "viz_overall_quality": {
      "type": "splunk.singlevalue",
      "title": "Overall Groundedness (1h)",
      "dataSources": { "primary": "ds_overall_quality" },
      "options": {
        "unit": "",
        "numberPrecision": 2,
        "majorColor": "> majorValue | rangeValue(qualityRange)",
        "trendDisplay": "absolute",
        "sparklineDisplay": "below"
      },
      "context": {
        "qualityRange": [
          { "to": 0.30, "value": "#D41F1F" },
          { "from": 0.30, "to": 0.60, "value": "#F1813F" },
          { "from": 0.60, "value": "#118832" }
        ]
      }
    },
    "viz_hallucination_rate": {
      "type": "splunk.singlevalue",
      "title": "Hallucination Rate (groundedness < 0.30)",
      "dataSources": { "primary": "ds_hallucination_rate" },
      "options": {
        "unit": "%",
        "unitPosition": "after",
        "numberPrecision": 1,
        "majorColor": "> majorValue | rangeValue(hallRange)"
      },
      "context": {
        "hallRange": [
          { "to": 2, "value": "#118832" },
          { "from": 2, "to": 5, "value": "#F1813F" },
          { "from": 5, "value": "#D41F1F" }
        ]
      }
    },
    "viz_context_impact": {
      "type": "splunk.singlevalue",
      "title": "Quality Lift With Retrieval Context",
      "dataSources": { "primary": "ds_context_impact" },
      "options": { "unit": "x", "unitPosition": "after", "numberPrecision": 1, "majorColor": "#0A84FF" }
    },
    "viz_quality_trend": {
      "type": "splunk.line",
      "title": "Groundedness by Model Version (7d) — regression shows as a cliff",
      "dataSources": { "primary": "ds_quality_trend" },
      "options": {
        "yAxisMin": 0,
        "yAxisMax": 1,
        "legendDisplay": "right",
        "yAxisTitleText": "avg groundedness",
        "showRoundedY": true
      }
    },
    "viz_model_table": {
      "type": "splunk.table",
      "title": "Model Comparison — quality, hallucinations, cost/call",
      "dataSources": { "primary": "ds_model_table" },
      "options": {
        "tableFormat": {
          "rowBackgroundColors": "> table | seriesByName('status') | matchValue(statusColors)"
        }
      },
      "context": {
        "statusColors": [
          { "match": "DEGRADED", "value": "#2A1A0A" },
          { "match": "GOOD", "value": "#0E1A0E" }
        ]
      }
    },
    "viz_agent_audit": {
      "type": "splunk.table",
      "title": "🤖 Agent Decision Audit Trail (sense → root-cause → act)",
      "dataSources": { "primary": "ds_agent_audit" },
      "options": {}
    }
  },
  "dataSources": {
    "ds_overall_quality": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events earliest=-1h | stats avg(groundedness_score) as quality | eval quality=round(quality,2)",
        "queryParameters": { "earliest": "-1h", "latest": "now" }
      },
      "name": "Overall quality"
    },
    "ds_hallucination_rate": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events earliest=-24h | stats count as total, count(eval(groundedness_score<0.3)) as halluc | eval rate=round(halluc/total*100,1) | fields rate",
        "queryParameters": { "earliest": "-24h", "latest": "now" }
      },
      "name": "Hallucination rate"
    },
    "ds_context_impact": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events earliest=-24h | stats avg(eval(if(context_provided=\"true\",groundedness_score,null()))) as with_ctx, avg(eval(if(context_provided=\"false\",groundedness_score,null()))) as no_ctx | eval lift=round(with_ctx/no_ctx,1) | fields lift",
        "queryParameters": { "earliest": "-24h", "latest": "now" }
      },
      "name": "Context impact"
    },
    "ds_quality_trend": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events | timechart span=1h avg(groundedness_score) as avg_quality by model_version",
        "queryParameters": { "earliest": "-7d@d", "latest": "now" }
      },
      "name": "Quality trend"
    },
    "ds_model_table": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events earliest=-24h | eval cost_per_call=(input_tokens*0.00001)+(output_tokens*0.00003) | stats avg(groundedness_score) as quality, count(eval(groundedness_score<0.3)) as hallucinations, avg(latency_ms) as latency_ms, avg(cost_per_call) as cost, count as calls by model_version | eval quality=round(quality,2), cost=round(cost,4), latency_ms=round(latency_ms,0), status=if(quality>=0.7,\"GOOD\",\"DEGRADED\") | sort -quality",
        "queryParameters": { "earliest": "-24h", "latest": "now" }
      },
      "name": "Model comparison"
    },
    "ds_agent_audit": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_agent_actions | table _time status regression.model_version regression.drop_pct root_cause.recommended_action root_cause.confidence result.detail | sort -_time",
        "queryParameters": { "earliest": "-7d@d", "latest": "now" }
      },
      "name": "Agent audit trail"
    }
  },
  "inputs": {
    "input_timerange": {
      "type": "input.timerange",
      "title": "Time range",
      "options": { "token": "global_time", "defaultValue": "-24h,now" }
    }
  },
  "layout": {
    "type": "grid",
    "globalInputs": ["input_timerange"],
    "options": { "width": 1440, "height": 960 },
    "structure": [
      { "item": "viz_overall_quality", "type": "block", "position": { "x": 0, "y": 0, "w": 480, "h": 220 } },
      { "item": "viz_hallucination_rate", "type": "block", "position": { "x": 480, "y": 0, "w": 480, "h": 220 } },
      { "item": "viz_context_impact", "type": "block", "position": { "x": 960, "y": 0, "w": 480, "h": 220 } },
      { "item": "viz_quality_trend", "type": "block", "position": { "x": 0, "y": 220, "w": 1440, "h": 320 } },
      { "item": "viz_model_table", "type": "block", "position": { "x": 0, "y": 540, "w": 720, "h": 400 } },
      { "item": "viz_agent_audit", "type": "block", "position": { "x": 720, "y": 540, "w": 720, "h": 400 } }
    ]
  }
}
