{
  "title": "LLMWatch \u2014 Quality & Cost Efficiency (30-Day)",
  "description": "Relationship between LLM answer quality and operational cost. Every panel is computed live from index=llmwatch \u2014 no hardcoded figures. Import via Dashboards \u2192 Create New \u2192 Dashboard Studio \u2192 Source.",
  "visualizations": {
    "viz_total_calls": {
      "type": "splunk.singlevalue",
      "title": "Total LLM Calls (30d)",
      "dataSources": {
        "primary": "ds_total_calls"
      },
      "options": {
        "numberPrecision": 0,
        "majorColor": "#0A84FF"
      }
    },
    "viz_halluc_caught": {
      "type": "splunk.singlevalue",
      "title": "Hallucinations Caught (groundedness < 0.30)",
      "dataSources": {
        "primary": "ds_halluc_caught"
      },
      "options": {
        "numberPrecision": 0,
        "majorColor": "#FF9500"
      }
    },
    "viz_regressions": {
      "type": "splunk.singlevalue",
      "title": "Regressions Detected by Agent",
      "dataSources": {
        "primary": "ds_regressions"
      },
      "options": {
        "numberPrecision": 0,
        "majorColor": "#FF3B30"
      }
    },
    "viz_context_lift": {
      "type": "splunk.singlevalue",
      "title": "Quality Lift With Context",
      "dataSources": {
        "primary": "ds_context_lift"
      },
      "options": {
        "unit": "x",
        "unitPosition": "after",
        "numberPrecision": 1,
        "majorColor": "#34C759"
      }
    },
    "viz_scatter": {
      "type": "splunk.bubble",
      "title": "Quality vs Cost by Model Version  \u2014  \u2191 better, \u2190 cheaper (bubble = call volume)",
      "dataSources": {
        "primary": "ds_scatter"
      },
      "options": {
        "xAxisTitleText": "Cost per 1K calls ($)",
        "yAxisTitleText": "Avg groundedness (0\u20131)",
        "yAxisMin": 0,
        "yAxisMax": 1,
        "legendDisplay": "right"
      }
    },
    "viz_qpd": {
      "type": "splunk.bar",
      "title": "Quality-per-Dollar Ranking \u2014 best value first",
      "dataSources": {
        "primary": "ds_qpd"
      },
      "options": {
        "legendDisplay": "off",
        "xAxisTitleText": "groundedness per $"
      }
    },
    "viz_context_impact": {
      "type": "splunk.column",
      "title": "Context Impact \u2014 groundedness with vs without retrieval context",
      "dataSources": {
        "primary": "ds_context_impact"
      },
      "options": {
        "yAxisMin": 0,
        "yAxisMax": 1,
        "legendDisplay": "right",
        "yAxisTitleText": "avg groundedness"
      }
    }
  },
  "dataSources": {
    "ds_total_calls": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events | stats count as calls | fields calls",
        "queryParameters": {
          "earliest": "-30d@d",
          "latest": "now"
        }
      },
      "name": "Total calls"
    },
    "ds_halluc_caught": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events | stats count(eval(groundedness_score<0.3)) as caught | fields caught",
        "queryParameters": {
          "earliest": "-30d@d",
          "latest": "now"
        }
      },
      "name": "Hallucinations caught"
    },
    "ds_regressions": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_agent_actions status=*regression* | stats count as regressions | fields regressions",
        "queryParameters": {
          "earliest": "-30d@d",
          "latest": "now"
        }
      },
      "name": "Regressions detected"
    },
    "ds_context_lift": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events | stats avg(eval(if(context_provided=\"true\",groundedness_score,null()))) as with_ctx, avg(eval(if(context_provided=\"false\",groundedness_score,null()))) as no_ctx | eval lift=round(with_ctx/no_ctx,1) | fields lift",
        "queryParameters": {
          "earliest": "-30d@d",
          "latest": "now"
        }
      },
      "name": "Context lift"
    },
    "ds_scatter": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events | eval cost_per_1k=((input_tokens*0.00001)+(output_tokens*0.00003))*1000 | stats avg(groundedness_score) as quality, avg(cost_per_1k) as cost_per_1k, count as calls by model_version | eval quality=round(quality,3), cost_per_1k=round(cost_per_1k,3) | table model_version cost_per_1k quality calls",
        "queryParameters": {
          "earliest": "-30d@d",
          "latest": "now"
        }
      },
      "name": "Quality vs cost"
    },
    "ds_qpd": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events | eval cost_per_call=(input_tokens*0.00001)+(output_tokens*0.00003) | stats avg(groundedness_score) as quality, avg(cost_per_call) as cost by model_version | eval quality_per_dollar=round(quality/cost,1) | sort -quality_per_dollar | table model_version quality_per_dollar",
        "queryParameters": {
          "earliest": "-30d@d",
          "latest": "now"
        }
      },
      "name": "Quality per dollar"
    },
    "ds_context_impact": {
      "type": "ds.search",
      "options": {
        "query": "index=llmwatch sourcetype=llm_events | eval ctx=if(context_provided=\"true\",\"with context\",\"without context\") | chart avg(groundedness_score) as groundedness over model_version by ctx",
        "queryParameters": {
          "earliest": "-30d@d",
          "latest": "now"
        }
      },
      "name": "Context impact"
    }
  },
  "inputs": {
    "input_timerange": {
      "type": "input.timerange",
      "title": "Time range",
      "options": {
        "token": "global_time",
        "defaultValue": "-30d@d,now"
      }
    }
  },
  "layout": {
    "tabs": {
      "items": [
        {
          "layoutId": "layout_1",
          "label": "Overview"
        }
      ]
    },
    "layoutDefinitions": {
