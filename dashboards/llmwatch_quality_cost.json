        "options": {
          "width": 1440,
          "height": 1040,
          "display": "fit-to-width",
          "backgroundColor": "transparent"
        },
        "structure": [
          {
            "item": "viz_total_calls",
            "type": "block",
            "position": {
              "x": 0,
              "y": 0,
              "w": 360,
              "h": 200
            }
          },
          {
            "item": "viz_halluc_caught",
            "type": "block",
            "position": {
              "x": 360,
              "y": 0,
              "w": 360,
              "h": 200
            }
          },
          {
            "item": "viz_regressions",
            "type": "block",
            "position": {
              "x": 720,
